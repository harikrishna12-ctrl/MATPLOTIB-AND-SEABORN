import seaborn as sns
import matplotlib.pyplot as plt


sns.set_theme()


sns.get_dataset_names()


tips =sns.load_dataset("tips")
print(tips)


sns.set_theme(style ="ticks")
sns.relplot(
    data = tips,
    x ="total_bill",
    y = "tip",
    kind ="line",
    hue ="smoker",
    size ="size",
    style = "smoker"
)


tips =sns.load_dataset("tips")
sns.barplot(
    data = tips,
    x ="day",
    y ="tip",
    hue ="sex"
)




sns.boxplot(
    data = tips,
    x ="day",
    y ="tip",
    hue ="sex"
)



